# ---- Server ----
PORT=3000
ALLOWED_ORIGINS=https://unitedinone.org,https://www.unitedinone.org,http://54.211.205.141

# ---- Resend (email) — https://resend.com  (Login with GitHub) ----
# Dashboard -> API Keys -> Create API Key (starts with "re_")
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# The "from" address. The domain must be verified in Resend (Domains -> Add Domain).
# Until verified, use the test sender below (only emails your own Resend login).
MAIL_FROM=onboarding@resend.dev
ADMIN_EMAIL=info@unitedinone.org

# ---- Vercel Blob (private file storage) — https://vercel.com/storage/blob ----
# Blob store -> ".env.local" tab -> BLOB_READ_WRITE_TOKEN (starts with "vercel_blob_rw_")
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx

# Long random string; required as ?key= to view stored files via /api/file
ADMIN_FILE_KEY=change-me-to-a-long-random-string

PORTAL_URL=http://54.211.205.141:3000
